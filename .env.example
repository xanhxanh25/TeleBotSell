# Shared env for docker-compose services

ENV=prod

# Postgres connection used by backend/adminweb in Docker network
DATABASE_URL=postgresql+psycopg2://postgres:postgres@postgres:5432/tele_shop

# API keys
ADMIN_API_KEY=change_me_long_random
BOT_API_KEY=change_me_bot
BACKEND_BOT_API_KEY=change_me_bot

# TokenPay integration
TOKENPAY_API_BASE=http://tokenpay:5001
TOKENPAY_API_TOKEN=change_me_tokenpay_token
# URL mà TokenPay gọi tới webhook backend (phải tới được từ container tokenpay).
# Trong Docker Compose: http://token_shop_backend:8000
# Nếu đặt https://domain... thì domain đó phải resolve tới backend (reverse proxy).
PUBLIC_BASE_URL=http://token_shop_backend:8000

# AdminWeb auth/session
ADMIN_SECRET_KEY=change_me_very_secret
ADMIN_PASSWORD_HASH=replace_with_sha256_hash

# APITELE
BOT_TOKEN=replace_with_real_telegram_bot_token
ORDER_API_BASE=http://token_shop_backend:8000
PAYMENT_API_BASE=http://token_shop_backend:8000
ADMIN_API_BASE=http://adminweb:8001
HTTP_TIMEOUT_SEC=20
HTTP_RETRIES=2
