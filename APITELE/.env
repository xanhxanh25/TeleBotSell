BOT_TOKEN="Tự Thêm Đi"

# Backend endpoints
ORDER_API_BASE=http://127.0.0.1:8000
PAYMENT_API_BASE=http://127.0.0.1:8000
ADMIN_API_BASE=http://127.0.0.1:8000

# Must match token_shop_backend BOT_API_KEY
BACKEND_BOT_API_KEY=change_me_bot

# Runtime
ENV=prod
LOG_DIR=logs

# Rate limiting
RATE_LIMIT_PER_MIN=60
FLOOD_WINDOW_SEC=6
FLOOD_MAX_MSG=8

# HTTP client
HTTP_TIMEOUT_SEC=5
HTTP_RETRIES=2

# Telegram API
TELEGRAM_API_TIMEOUT=60
TELEGRAM_API_RETRIES=3
TELEGRAM_VERIFY_ON_START=false

# Topup polling (10s × 190 = ~31.7 phút, đủ cover 30 phút cancel)
TOPUP_POLL_INTERVAL_SEC=10
TOPUP_POLL_MAX_TIMES=190

# Keepalive
KEEPALIVE_ENABLED=true
KEEPALIVE_INTERVAL_SEC=300
KEEPALIVE_TIMEOUT_SEC=8
